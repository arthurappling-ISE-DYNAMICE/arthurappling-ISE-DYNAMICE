    stroke: "#C9A646"
    stroke-width: 2
    border-radius: 6
  }
}

# ─── OUTPUTS / DOWNSTREAM SYSTEMS ────────────────────────────────────────────
github: {
  label: "GitHub\nRepository"
  shape: cylinder
  style: {
    fill: "#0B0B0B"
    font-color: "#888888"
    font-size: 12
    stroke: "#444444"
    stroke-width: 1
  }
}

agents: {
  label: "AI Agent\nPrompts (×5)"
  shape: oval
  style: {
    fill: "#0B0B0B"
    font-color: "#888888"
    font-size: 12
    stroke: "#444444"
    stroke-width: 1
  }
}

tools: {

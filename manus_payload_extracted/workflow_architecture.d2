direction: down

vars: {
  d2-config: {
    theme-id: 200
  }
}

title: {
  label: "PRIME PATHWY — SOVEREIGN SYSTEM ARCHITECTURE\nManus Master Credit Maximization System · Workflow Relationship Map"
  near: top-center
  style: {
    font-size: 22
    bold: true
    font-color: "#C9A646"
  }
}

# ─── CORE OPERATOR ───────────────────────────────────────────────────────────
operator: {
  label: "SOVEREIGN OPERATOR\nArthur F. Appling Sr."
  shape: hexagon
  style: {
    fill: "#C9A646"
    font-color: "#0B0B0B"
    bold: true
    font-size: 16
    stroke: "#C9A646"
    stroke-width: 3
  }
}

# ─── FIVE WORKFLOWS ──────────────────────────────────────────────────────────
wf1: {
  label: "WF-01\nINSTITUTIONAL\nKNOWLEDGE VAULT"
  shape: rectangle
  style: {
    fill: "#1A1A1A"
    font-color: "#C9A646"
    bold: true
    font-size: 13
    stroke: "#C9A646"
    stroke-width: 2
    border-radius: 6
  }
}

wf2: {
  label: "WF-02\nOPERATOR\nTRAINING SYSTEM"
  shape: rectangle
  style: {
    fill: "#1A1A1A"
    font-color: "#C9A646"
    bold: true
    font-size: 13
    stroke: "#C9A646"
    stroke-width: 2
    border-radius: 6
  }
}


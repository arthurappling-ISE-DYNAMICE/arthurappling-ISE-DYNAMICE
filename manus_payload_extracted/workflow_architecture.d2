  }
}

master_index: {
  label: "MASTER_INDEX.md\n(Ecosystem Map)"
  shape: document
  style: {
    fill: "#0B0B0B"
    font-color: "#888888"
    font-size: 12
    stroke: "#444444"
    stroke-width: 1
  }
}

# ─── CONNECTIONS: OPERATOR → WORKFLOWS ───────────────────────────────────────
operator -> wf1: {
  label: "Builds"
  style: { stroke: "#C9A646"; font-color: "#C9A646"; font-size: 11 }
}
